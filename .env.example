# Nebius Token Factory (OpenAI-compatible LLM inference)
# Get a key: https://tokenfactory.nebius.com  ->  API keys
NEBIUS_API_KEY=

# Vapi (voice agents) — used by the Vapi skills/MCP
VAPI_API_PRIVATE_KEY=
VAPI_API_PUBLIC_KEY=
# Output of `npm run vapi:bootstrap` (the created assistant id)
VAPI_ASSISTANT_ID=

# InsForge backend (BaaS: database, storage, edge functions)
# Get these from the InsForge dashboard / `npx @insforge/install`
INSFORGE_BASE_URL=https://your-app.region.insforge.app
INSFORGE_API_KEY=ik_...      # admin key — server-side only (provisioning, scripts, edge-function secret)
INSFORGE_ANON_KEY=anon_...   # public key — safe for the browser SDK (read-only by default)

# Browser-exposed values for the Vite app (VITE_ prefix required). Mirror the values above.
VITE_INSFORGE_BASE_URL=https://your-app.region.insforge.app
VITE_INSFORGE_ANON_KEY=anon_...
VITE_VAPI_PUBLIC_KEY=
VITE_VAPI_ASSISTANT_ID=      # filled in after `npm run vapi:bootstrap`
